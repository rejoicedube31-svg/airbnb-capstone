# Backend environment variables

# Copy to backend/.env:
#   copy .env.example .env

# Server port
PORT=5000

# MongoDB — local or Atlas (use mongodb:// not mongodb+srv on Windows if SRV fails)
MONGODB_URI=mongodb://127.0.0.1:27017/airbnb-capstone

# JWT signing secret — use a long random string in production (32+ characters)
JWT_SECRET=change-this-to-a-long-random-string

# Optional — restrict CORS in production (comma-separated React app URLs)
# Leave unset during local dev to allow all origins
# CLIENT_URL=http://localhost:5173
# ADMIN_URL=http://localhost:5174

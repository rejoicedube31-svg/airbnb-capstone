# Copy to backend/.env (Day 2+):
#   cd backend
#   copy .env.example .env
# Replace values with your own — do not commit .env to git.

PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/airbnb-capstone
JWT_SECRET=change-this-to-a-long-random-string

